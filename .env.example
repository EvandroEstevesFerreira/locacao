# ============================================================================
# Loca — variáveis de ambiente. Copie para .env.local e preencha.
# ============================================================================

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave secreta (service_role) — usada apenas em rotas de servidor/cron. NUNCA no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (Fase 5 — envio de e-mails de aviso)
RESEND_API_KEY=
# Remetente verificado no Resend (ex.: avisos@sistenge.com)
EMAIL_FROM=

# Segredo do Vercel Cron (Fase 5) — protege a rota /api/cron/*
CRON_SECRET=

# URL pública do app (usada em e-mails e links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
